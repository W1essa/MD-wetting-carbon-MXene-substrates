# ==============================================================================
# 1. EXPORT GRAPHENE DIMENSIONS
# Reads flat graphene and writes its in-plane dimensions to build_dims.vars
# ==============================================================================

shell rm -f build_dims.vars

units          real
atom_style     full
boundary       p p f

variable gfile string ../data/graphene_flat_initial.data
read_data      ${gfile}

group C type 1

# --- 2. Measure graphene extents ---
compute xC_min C reduce min x
compute xC_max C reduce max x
compute yC_min C reduce min y
compute yC_max C reduce max y
compute cZ_max C reduce max z

run 0 post no

variable xmin_g equal c_xC_min
variable xmax_g equal c_xC_max
variable ymin_g equal c_yC_min
variable ymax_g equal c_yC_max

variable Lx_g   equal ${xmax_g}-${xmin_g}
variable Ly_g   equal ${ymax_g}-${ymin_g}
variable xmid_g equal 0.5*(${xmax_g}+${xmin_g})
variable ymid_g equal 0.5*(${ymax_g}+${ymin_g})
variable zmaxC  equal c_cZ_max

# --- 3. Save reusable geometry variables ---
print "variable sys_xlo equal ${xmin_g}"  file   build_dims.vars screen no
print "variable sys_xhi equal ${xmax_g}"  append build_dims.vars screen no
print "variable sys_ylo equal ${ymin_g}"  append build_dims.vars screen no
print "variable sys_yhi equal ${ymax_g}"  append build_dims.vars screen no

print "variable Lx_g   equal ${Lx_g}"     append build_dims.vars screen no
print "variable Ly_g   equal ${Ly_g}"     append build_dims.vars screen no
print "variable xmid_g equal ${xmid_g}"   append build_dims.vars screen no
print "variable ymid_g equal ${ymid_g}"   append build_dims.vars screen no
print "variable zmaxC  equal ${zmaxC}"    append build_dims.vars screen no
clear


# ==============================================================================
# 2.BUILD WATER CYLINDER
# Replicates equilibrated water, cuts a cylinder, fixes image flags, writes file
# ==============================================================================

units          real
atom_style     full
boundary       p p p

pair_style     zero 10.0 nocoeff
bond_style     zero
angle_style    zero
kspace_style   none
special_bonds  lj/coul 0.0 0.0 0.0

variable wfile string ../data/water_equilibrated_for_droplet_nocoef.data
read_data      ${wfile} nocoeff

# --- 4. Dummy coeffs for initialization ---
pair_coeff      * *
bond_coeff      1 1.0
angle_coeff     1 109.47

mass           1 15.9994
mass           2 1.008

include        build_dims.vars

# --- 5. Extend water along Y beyond the graphene length ---
variable Ny equal ceil(${Ly_g}/ly) + 1
replicate 1 ${Ny} 1 bond/periodic

group          W type 1 2

# --- 6. Cut cylindrical water region ---
variable wx equal xcm(W,x)
variable wz equal xcm(W,z)
variable R  equal 25.0

region         keep_cyl cylinder y ${wx} ${wz} ${R} EDGE EDGE units box
group          keep region keep_cyl
group          drop subtract W keep
delete_atoms   group drop mol yes

group          W clear
group          W type 1 2

# --- 7. Rebuild molecule IDs ---
reset_atoms    mol W compress yes offset 0 single no

# --- 8. Increase communication range for image repair ---
comm_modify    cutoff 400.0

# --- 9. Rebuild image flags consistently ---
set            group W image 0 0 0
reset_atoms    image W

# --- 10. Remove molecules touching the Y seam ---
variable       edge equal 2.0
region         ylo_edge block INF INF EDGE $(ylo+v_edge) INF INF units box
region         yhi_edge block INF INF $(yhi-v_edge) EDGE INF INF units box
group          seam_lo region ylo_edge
group          seam_hi region yhi_edge
group          seam union seam_lo seam_hi
delete_atoms   group seam mol yes

group          W clear
group          W type 1 2

# --- 11. Final topology cleanup ---
reset_atoms    mol W compress yes offset 0 single no
set            group W image 0 0 0
reset_atoms    image W
comm_modify    cutoff 10.0
velocity       all set 0.0 0.0 0.0 units box

write_data     ../data/water_cylinder.data nocoeff

print "SUCCESS: water cylinder file written."